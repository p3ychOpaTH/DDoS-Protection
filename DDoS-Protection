class TrafficSimulator:
    """
    DDoS traffic simulator for testing and validation.
    Generates realistic attack patterns to verify shield effectiveness.
    WARNING: Only for authorized testing in isolated environments.
    """
    
    def __init__(self):
        self.active_simulations: Dict[str, asyncio.Task] = {}
        self.simulation_stats: Dict[str, Dict[str, int]] = {}
        
    async def simulate_attack(self, vector: AttackVector,
                            target_ip: str, pps: int = 10000,
                            duration_sec: int = 30):
        """Simulate a specific DDoS attack vector."""
        sim_id = f"sim_{vector.name}_{int(time.time())}"
        
        logging.info(f"Starting simulation {sim_id}: {vector.name} -> {target_ip} "
                    f"at {pps} pps for {duration_sec}s")
        
        self.simulation_stats[sim_id] = {
            "vector": vector.name,
            "target": target_ip,
            "pps": pps,
            "packets_sent": 0,
            "started": time.time()
        }
        
        async def attack_loop():
            end_time = time.time() + duration_sec
            interval = 1.0 / pps
            
            while time.time() < end_time:
                packet = self._generate_attack_packet(vector, target_ip)
                
                # Would inject packet into shield processing pipeline
                self.simulation_stats[sim_id]["packets_sent"] += 1
                
                await asyncio.sleep(interval)
            
            logging.info(f"Simulation {sim_id} completed: "
                        f"{self.simulation_stats[sim_id]['packets_sent']} packets sent")
        
        task = asyncio.create_task(attack_loop())
        self.active_simulations[sim_id] = task
        return sim_id
    
    def _generate_attack_packet(self, vector: AttackVector,
                               target_ip: str) -> bytes:
        """Generate a realistic attack packet for the given vector."""
        dst_ip = struct.unpack("!I", socket.inet_aton(target_ip))[0]
        src_ip = struct.unpack("!I", socket.inet_aton(
            f"{random.randint(1,255)}.{random.randint(0,255)}."
            f"{random.randint(0,255)}.{random.randint(1,254)}"
        ))[0]
        
        if vector == AttackVector.SYN_FLOOD:
            # TCP SYN packet
            packet = struct.pack(
                "!BBHHHBBHIIHHHH",
                0x45, 0x00, 0x0034, random.randint(0, 65535),
                0x4000, 0x40, 6, 0,
                src_ip, dst_ip,
                random.randint(1024, 65535), 80,
                random.randint(0, 0xFFFFFFFF), 0,
                0x5002, 0xFFFF,
                0x0000, 0x0000
            )
        elif vector == AttackVector.UDP_FLOOD:
            # UDP packet
            packet = struct.pack(
                "!BBHHHBBHIIHHH",
                0x45, 0x00, 0x001C, random.randint(0, 65535),
                0x4000, 0x40, 17, 0,
                src_ip, dst_ip,
                random.randint(1024, 65535), 53,
                0x0008, 0x0000
            )
        elif vector == AttackVector.ICMP_FLOOD:
            # ICMP echo request
            packet = struct.pack(
                "!BBHHHBBHIIBBHHH",
                0x45, 0x00, 0x0020, random.randint(0, 65535),
                0x4000, 0x40, 1, 0,
                src_ip, dst_ip,
                8, 0, 0x0000, 0
            )
        elif vector == AttackVector.HTTP_FLOOD:
            # HTTP GET request
            http_request = b"GET / HTTP/1.1\r\nHost: target.com\r\n\r\n"
            # TCP packet with HTTP payload
            packet = struct.pack(
                "!BBHHHBBHIIHHHH",
                0x45, 0x00, 0x0034 + len(http_request),
                random.randint(0, 65535),
                0x4000, 0x40, 6, 0,
                src_ip, dst_ip,
                random.randint(1024, 65535), 80,
                random.randint(0, 0xFFFFFFFF),
                random.randint(0, 0xFFFFFFFF),
                0x5018, 0xFFFF,
                0x0000, 0x0000
            ) + http_request
        else:
            # Generic packet
            packet = struct.pack(
                "!BBHHHBBHII",
                0x45, 0x00, 0x0014, random.randint(0, 65535),
                0x4000, 0x40, 6, 0,
                src_ip, dst_ip
            )
        
        return packet
    
    def stop_simulation(self, sim_id: str):
        """Stop a running simulation."""
        if sim_id in self.active_simulations:
            self.active_simulations[sim_id].cancel()
            del self.active_simulations[sim_id]
            logging.info(f"Simulation {sim_id} stopped")


