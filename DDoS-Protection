class HyperionDaemon:
    """
    Daemon manager for HYPERION SHIELD.
    Handles startup, shutdown, PID management, and process supervision.
    """
    
    def __init__(self, shield: 'HyperionShield'):
        self.shield = shield
        self.pid_file = Path("/var/run/hyperion/shield.pid")
        self.lock_file = Path("/var/lock/hyperion.lock")
        self.running = False
        self.components: List[asyncio.Task] = []
        self.forensic_logger = ForensicLogger()
        
    async def daemonize(self):
        """Daemonize the shield process."""
        # Double fork to daemonize
        try:
            pid = os.fork()
            if pid > 0:
                sys.exit(0)
        except OSError:
            sys.exit(1)
        
        os.chdir("/")
        os.setsid()
        os.umask(0o027)
        
        try:
            pid = os.fork()
            if pid > 0:
                sys.exit(0)
        except OSError:
            sys.exit(1)
        
        # Redirect standard file descriptors
        sys.stdout.flush()
        sys.stderr.flush()
        
        dev_null = os.open(os.devnull, os.O_RDWR)
        os.dup2(dev_null, sys.stdin.fileno())
        os.dup2(dev_null, sys.stdout.fileno())
        os.dup2(dev_null, sys.stderr.fileno())
        os.close(dev_null)
        
        # Write PID file
        self.pid_file.parent.mkdir(parents=True, exist_ok=True)
        with open(self.pid_file, 'w') as f:
            f.write(str(os.getpid()))
        
        # Create lock file
        self.lock_file.touch()
        
        logging.info(f"Daemon started with PID {os.getpid()}")
    
    async def start(self, daemonize: bool = False):
        """Start the Hyperion Shield daemon."""
        if daemonize:
            await self.daemonize()
        
        self.running = True
        
        # Initialize forensic logger
        await self.forensic_logger.initialize()
        await self.forensic_logger.log_event(
            "SHIELD_STARTUP",
            {"version": DefenseConstants.VERSION,
             "codename": DefenseConstants.CODENAME},
            "CRITICAL"
        )
        
        # Initialize configuration
        self.shield.config = ConfigurationManager()
        await self.shield.config.load_config()
        
        # Initialize GeoIP
        self.shield.geoip = GeoIPLoader()
        await self.shield.geoip.initialize()
        
        # Initialize shield core
        await self.shield.initialize()
        
        # Start components
        self.components = []
        
        # API Server
        api = ShieldAPI(self.shield)
        self.components.append(asyncio.create_task(api.start()))
        
        # Prometheus Server
        prom_server = PrometheusMetricsServer(self.shield)
        self.components.append(asyncio.create_task(prom_server.start()))
        
        # Packet Capture
        capture = XDPPacketCapture()
        if await capture.initialize():
            self.components.append(
                asyncio.create_task(capture.capture_loop(self.shield))
            )
            self.shield.capture = capture
        
        # Automated Response
        response_system = AutomatedResponseSystem(self.shield)
        self.components.append(
            asyncio.create_task(response_system.process_response_queue())
        )
        
        logging.info(f"All components started ({len(self.components)} tasks)")
        
        # Log startup complete
        await self.forensic_logger.log_event(
            "SHIELD_OPERATIONAL",
            {"components": len(self.components)},
            "CRITICAL"
        )
        
        # Wait for all components
        try:
            await asyncio.gather(*self.components)
        except asyncio.CancelledError:
            pass
    
    async def shutdown(self):
        """Graceful shutdown of all components."""
        logging.info("Initiating graceful shutdown...")
        self.running = False
        
        await self.forensic_logger.log_event(
            "SHIELD_SHUTDOWN",
            {"reason": "operator_request"},
            "CRITICAL"
        )
        
        # Cancel all tasks
        for task in self.components:
            task.cancel()
        
        # Wait for tasks to complete
        await asyncio.gather(*self.components, return_exceptions=True)
        
        # Shutdown capture engine
        if hasattr(self.shield, 'capture'):
            await self.shield.capture.shutdown()
        
        # Verify forensic integrity before exit
        integrity_ok = await self.forensic_logger.verify_integrity()
        logging.info(f"Forensic integrity check: {'PASSED' if integrity_ok else 'FAILED'}")
        
        # Clean up PID and lock files
        if self.pid_file.exists():
            self.pid_file.unlink()
        if self.lock_file.exists():
            self.lock_file.unlink()
        
        logging.info("Hyperion Shield shutdown complete")


