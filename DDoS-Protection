    def _get_protocol_rate(self, ip_int: int, protocol: int) -> int:
        """Get packet rate per protocol per second."""
        if not hasattr(self, '_protocol_counter'):
            self._protocol_counter: Dict[Tuple[int, int], List[float]] = defaultdict(list)
        
        key = (ip_int, protocol)
        current = time.time()
        self._protocol_counter[key] = [
            t for t in self._protocol_counter[key] if t > current - 1
        ]
        self._protocol_counter[key].append(current)
        return len(self._protocol_counter[key])
    
    def _trigger_mitigation(self, vector: AttackVector, target: str):
        """Trigger automated mitigation for detected attack."""
        mitigation_key = f"{vector.name}:{target}"
        current_time = datetime.now(timezone.utc)
        
        if mitigation_key not in self._attack_mitigations:
            self._attack_mitigations[mitigation_key] = current_time
            self.metrics.attack_count += 1
            self.metrics.mitigation_active = True
            
            logging.warning(
                f"ATTACK DETECTED [{self.region}] Vector: {vector.name}, "
                f"Target: {target}, Time: {current_time.isoformat()}"
            )
            
            # Auto-blackhole for severe attacks
            if vector in (AttackVector.SYN_FLOOD, AttackVector.DNS_AMPLIFICATION,
                         AttackVector.UDP_FLOOD, AttackVector.CARPET_BOMBING):
                try:
                    ip_int = int(target.replace('.', '')) if '.' in target else 0
                    if ip_int and not hasattr(self, '_blackhole_list'):
                        self._blackhole_list: Set[int] = set()
                    if ip_int:
                        self._blackhole_list.add(ip_int)
                except ValueError:
                    pass
    
