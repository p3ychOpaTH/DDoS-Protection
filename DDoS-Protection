class PrometheusMetricsServer:
    """
    Prometheus-compatible metrics HTTP endpoint.
    Exposes all shield metrics for monitoring and alerting.
    """
    
    def __init__(self, shield: 'HyperionShield',
                 host: str = "0.0.0.0", port: int = 9090):
        self.shield = shield
        self.host = host
        self.port = port
        self.server = None
        
    async def start(self):
        """Start Prometheus metrics server."""
        try:
            self.server = await asyncio.start_server(
                self._handle_metrics_request,
                self.host, self.port
            )
            logging.info(f"Prometheus metrics server on {self.host}:{self.port}")
            
            async with self.server:
                await self.server.serve_forever()
                
        except Exception as e:
            logging.error(f"Prometheus server failed: {e}")
    
    async def _handle_metrics_request(self, reader: asyncio.StreamReader,
                                     writer: asyncio.StreamWriter):
        """Handle metrics scrape request."""
        try:
            # Read request
            request_line = await reader.readline()
            
            # Generate metrics
            metrics_text = self._generate_metrics()
            
            # Send response
            response = (
                "HTTP/1.1 200 OK\r\n"
                "Content-Type: text/plain; version=0.0.4\r\n"
                f"Content-Length: {len(metrics_text)}\r\n"
                "Connection: close\r\n"
                "\r\n"
            ).encode() + metrics_text.encode()
            
            writer.write(response)
            await writer.drain()
            
        except Exception:
            pass
        finally:
            writer.close()
    
    def _generate_metrics(self) -> str:
        """Generate Prometheus metrics text."""
        metrics = []
        status = self.shield.get_status()
        
        # Shield info
        metrics.append("# HELP hyperion_shield_info Shield version information")
        metrics.append("# TYPE hyperion_shield_info gauge")
        metrics.append(
            f'hyperion_shield_info{{version="{DefenseConstants.VERSION}",'
            f'codename="{DefenseConstants.CODENAME}",'
            f'author="{DefenseConstants.AUTHOR}"}} 1'
        )
        
        # Threat level
        metrics.append("# HELP hyperion_threat_level Current threat level")
        metrics.append("# TYPE hyperion_threat_level gauge")
        threat_levels = {"LOW": 0, "MEDIUM": 1, "HIGH": 2, "CRITICAL": 3}
        current_level = threat_levels.get(
            status['defense_status']['threat_level'], 0
        )
        metrics.append(f"hyperion_threat_level {current_level}")
        
        # Active attacks
        metrics.append("# HELP hyperion_active_attacks_total Total active DDoS attacks")
        metrics.append("# TYPE hyperion_active_attacks_total gauge")
        metrics.append(
            f"hyperion_active_attacks_total "
            f"{status['defense_status']['total_attacks_neutralized']}"
        )
        
        # Global capacity
        metrics.append("# HELP hyperion_global_capacity_tbps Total capacity in Tbps")
        metrics.append("# TYPE hyperion_global_capacity_tbps gauge")
        metrics.append(
            f"hyperion_global_capacity_tbps "
            f"{status['defense_status']['global_capacity_tbps']}"
        )
        
        # Per-center metrics
        for continent, centers in self.shield.anycast_controller.centers.items():
            for region, center in centers.items():
                label = f'{{continent="{continent}",region="{region}"}}'
                
                metrics.append(f"hyperion_center_healthy{label} "
                             f"{1 if center.is_healthy else 0}")
                metrics.append(f"hyperion_center_load_factor{label} "
                             f"{center.load_factor}")
                metrics.append(f"hyperion_center_pps{label} "
                             f"{center.metrics.pps_current}")
                metrics.append(f"hyperion_center_packets_dropped{label} "
                             f"{center.metrics.packets_dropped}")
                metrics.append(f"hyperion_center_attack_count{label} "
                             f"{center.metrics.attack_count}")
        
        # Cache metrics
        cache_stats = self.shield.cdn.get_cache_stats()
        metrics.append("# HELP hyperion_cache_hits_total Total cache hits")
        metrics.append("# TYPE hyperion_cache_hits_total counter")
        metrics.append(f"hyperion_cache_hits_total {cache_stats['hits']}")
        
        metrics.append("# HELP hyperion_cache_misses_total Total cache misses")
        metrics.append("# TYPE hyperion_cache_misses_total counter")
        metrics.append(f"hyperion_cache_misses_total {cache_stats['misses']}")
        
        return "\n".join(metrics) + "\n"


