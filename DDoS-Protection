@dataclass(slots=True, frozen=True)
class FlowKey:
    """Immutable 5-tuple flow identifier for connection tracking."""
    src_ip: int  # 32-bit integer representation
    dst_ip: int
    src_port: int
    dst_port: int
    protocol: int  # 6=TCP, 17=UDP, 1=ICMP
    
    @classmethod
    def from_packet(cls, packet: bytes) -> 'FlowKey':
        """Extract flow key from raw packet bytes."""
        version = (packet[0] >> 4) & 0x0F
        if version == 4:
            protocol = packet[9]
            src_ip = struct.unpack("!I", packet[12:16])[0]
            dst_ip = struct.unpack("!I", packet[16:20])[0]
            ihl = (packet[0] & 0x0F) * 4
            if protocol in (6, 17):  # TCP or UDP
                src_port = struct.unpack("!H", packet[ihl:ihl+2])[0]
                dst_port = struct.unpack("!H", packet[ihl+2:ihl+4])[0]
            else:
                src_port = dst_port = 0
            return cls(src_ip, dst_ip, src_port, dst_port, protocol)
        elif version == 6:
            raise NotImplementedError("IPv6 flow extraction")
        raise ValueError("Invalid IP version")
    
    def __hash__(self) -> int:
        return hash((self.src_ip, self.dst_ip, self.src_port,
                     self.dst_port, self.protocol))
    
    def reverse(self) -> 'FlowKey':
        """Return the reverse flow key."""
        return FlowKey(self.dst_ip, self.src_ip, self.dst_port,
                       self.src_port, self.protocol)


