class AIEnsembleModel:
    """
    Ensemble AI Model for DDoS Attack Detection.
    Combines multiple ML approaches for robust detection.
    """
    
    def __init__(self):
        self.ensemble_weights = np.array([0.15, 0.15, 0.15, 0.15, 0.15, 0.15, 0.10])
        self.models = []
        self.scaler = RobustScaler()
        self._initialize_models()
        self.attack_classifier = AttackClassifier()
    
    def _initialize_models(self):
        """Initialize ensemble of ML models."""
        try:
            # XGBoost model
            model1 = xgb.XGBClassifier(
                n_estimators=500,
                max_depth=12,
                learning_rate=0.05,
                subsample=0.8,
                colsample_bytree=0.8,
                objective='multi:softprob',
                num_class=len(AttackVector),
                tree_method='hist'
            )
            self.models.append(("xgboost", model1))
            
            # LightGBM model
            model2 = lgb.LGBMClassifier(
                n_estimators=500,
                max_depth=10,
                learning_rate=0.05,
                num_leaves=128,
                subsample=0.8,
                colsample_bytree=0.8
            )
            self.models.append(("lightgbm", model2))
            
            # Random Forest
            model3 = RandomForestClassifier(
                n_estimators=300,
                max_depth=15,
                min_samples_split=5,
                min_samples_leaf=2,
                n_jobs=-1
            )
            self.models.append(("random_forest", model3))
            
            # Isolation Forest for anomaly detection
            model4 = IsolationForest(
                n_estimators=200,
                max_samples=0.8,
                contamination=0.1,
                random_state=42
            )
            self.models.append(("isolation_forest", model4))
            
            # Local Outlier Factor
            model5 = LocalOutlierFactor(
                n_neighbors=20,
                contamination=0.1,
                novelty=True
            )
            self.models.append(("lof", model5))
            
            # Neural Network (PyTorch)
            model6 = DeepAnomalyDetector()
            self.models.append(("deep_nn", model6))
            
            # DBSCAN-based detector
            model7 = DBSCAN(eps=0.5, min_samples=10)
            self.models.append(("dbscan", model7))
            
        except Exception as e:
            logging.error(f"Model initialization partial: {e}")
    
    def predict_proba(self, features: np.ndarray) -> np.ndarray:
        """
        Ensemble prediction.
        Returns array of shape (1, n_classes) with probability scores.
        """
        predictions = []
        
        for name, model in self.models:
            try:
                if name == "xgboost":
                    proba = model.predict_proba(features)
                    predictions.append(proba)
                elif name == "lightgbm":
                    proba = model.predict_proba(features)
                    predictions.append(proba)
                elif name == "random_forest":
                    proba = model.predict_proba(features)
                    predictions.append(proba)
                elif name == "isolation_forest":
                    scores = model.score_samples(features)
                    proba = self._scores_to_proba(scores)
                    predictions.append(proba)
                elif name == "lof":
                    scores = -model.score_samples(features)
                    proba = self._scores_to_proba(scores)
                    predictions.append(proba)
                elif name == "deep_nn":
                    proba = model.predict_proba(features)
                    predictions.append(proba)
                elif name == "dbscan":
                    scores = np.zeros((1, len(AttackVector)))
                    predictions.append(scores)
            except Exception:
                predictions.append(np.zeros((1, len(AttackVector))))
        
        if predictions:
            return np.mean(predictions, axis=0)
        return np.zeros((1, len(AttackVector)))
    
    def _scores_to_proba(self, scores: np.ndarray) -> np.ndarray:
        """Convert anomaly scores to probabilities."""
        proba = np.zeros((len(scores), len(AttackVector)))
        normalized = 1 / (1 + np.exp(-scores))
        proba[:, 0] = 1 - normalized
        for i in range(1, len(AttackVector)):
            proba[:, i] = normalized / (len(AttackVector) - 1)
        return proba
    
    def classify_attack(self, features: np.ndarray) -> Optional[AttackVector]:
        """Classify the type of attack."""
        return self.attack_classifier.classify(features)


class DeepAnomalyDetector:
    """Deep learning anomaly detector using PyTorch."""
    
    def __init__(self):
        self.model = self._build_model()
        self.threshold = DefenseConstants.ML_ANOMALY_THRESHOLD
    
    def _build_model(self):
        """Build deep neural network architecture."""
        try:
            model = nn.Sequential(
                nn.Linear(DefenseConstants.ML_FEATURE_COUNT, 512),
                nn.BatchNorm1d(512),
                nn.ReLU(),
                nn.Dropout(0.3),
                
                nn.Linear(512, 256),
                nn.BatchNorm1d(256),
                nn.ReLU(),
                nn.Dropout(0.3),
                
                nn.Linear(256, 128),
                nn.BatchNorm1d(128),
                nn.ReLU(),
                nn.Dropout(0.2),
                
                nn.Linear(128, 64),
                nn.BatchNorm1d(64),
                nn.ReLU(),
                
                nn.Linear(64, 32),
                nn.ReLU(),
                
                nn.Linear(32, len(AttackVector)),
                nn.Softmax(dim=1)
            )
            return model
        except Exception:
            return None
    
    def predict_proba(self, features: np.ndarray) -> np.ndarray:
        """Make prediction with neural network."""
        if self.model is None:
            return np.zeros((1, len(AttackVector)))
        
        try:
            tensor = torch.FloatTensor(features)
            with torch.no_grad():
                output = self.model(tensor)
                return output.numpy()
        except Exception:
            return np.zeros((1, len(AttackVector)))


class AttackClassifier:
    """Classify attack types based on feature patterns."""
    
    def classify(self, features: np.ndarray) -> Optional[AttackVector]:
        """Classify attack vector from features."""
        # Simplified rule-based classification
        packet_size = features[0][0] if hasattr(features, '__getitem__') else features[0]
        protocol = features[0][3] if hasattr(features, '__getitem__') else 0
        pps = features[0][64] if hasattr(features, '__getitem__') else 0
        
        if protocol == 6 and pps > 50000:
            return AttackVector.SYN_FLOOD
        elif protocol == 17 and pps > 100000:
            return AttackVector.UDP_FLOOD
        elif protocol == 1 and pps > 10000:
            return AttackVector.ICMP_FLOOD
        
        return AttackVector.ZERO_DAY_VECTOR


