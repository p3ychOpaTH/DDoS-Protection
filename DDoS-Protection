                    "hyperion_mitigation_triggers_total",
                    "Times mitigation was triggered",
                    ["region", "vector"]
                ),
                "latency_histogram": Histogram(
                    "hyperion_packet_latency_ms",
                    "Packet processing latency",
                    ["region"],
                    buckets=[0.1, 0.5, 1, 2, 5, 10, 20, 50, 100]
                ),
            }
        except Exception:
            self.metrics = {}
    
    async def record_packet(self, verdict: PacketVerdict, region: str,
                           latency_ms: float = 0.0):
        """Record a packet processing event."""
        event = {
            "timestamp": time.time(),
            "verdict": verdict.value,
            "region": region,
            "latency_ms": latency_ms
        }
        await self.metrics_queue.put(event)
        
        # Update Prometheus metrics
        if self.metrics:
            try:
                self.metrics["packets_total"].labels(
                    region=region, verdict=verdict.value
                ).inc()
                
                if verdict == PacketVerdict.DROP:
                    self.metrics["packet_drops"].labels(
                        region=region, reason="malicious"
                    ).inc()
                
                self.metrics["latency_histogram"].labels(
                    region=region
                ).observe(latency_ms)
            except Exception:
                pass
    
    async def record_mitigation(self, region: str, vector: AttackVector):
        """Record an attack mitigation event."""
        if self.metrics:
            try:
                self.metrics["mitigation_triggers"].labels(
                    region=region, vector=vector.name
                ).inc()
                self.metrics["active_attacks"].labels(
                    region=region, vector=vector.name
                ).inc()
            except Exception:
                pass
    
    async def update_load_metrics(self, region: str, load: float,
                                  bandwidth_in: float, bandwidth_out: float):
        """Update load metrics for a region."""
        if self.metrics:
            try:
                self.metrics["scrubber_load"].labels(region=region).set(load * 100)
                self.metrics["bandwidth_mbps"].labels(
                    region=region, direction="in"
                ).set(bandwidth_in)
                self.metrics["bandwidth_mbps"].labels(
                    region=region, direction="out"
                ).set(bandwidth_out)
            except Exception:
                pass
    
    async def flush_metrics(self):
        """Periodically flush metrics to persistent storage."""
        while True:
            batch = []
            while not self.metrics_queue.empty() and len(batch) < 1000:
                try:
                    event = await asyncio.wait_for(
                        self.metrics_queue.get(), timeout=0.1
                    )
                    batch.append(event)
                except asyncio.TimeoutError:
                    break
            
            if batch:
                self.metrics_history.append({
                    "timestamp": time.time(),
                    "events": batch
                })
                
                # Check alert thresholds
                await self._check_alerts(batch)
            
            await asyncio.sleep(DefenseConstants.TELEMETRY_FLUSH_INTERVAL)
    
    async def _check_alerts(self, batch: List[Dict]):
        """Check metrics against alert thresholds."""
        if not batch:
            return
        
        drops = sum(1 for e in batch if e["verdict"] == "drop")
        total = len(batch)
        
        if total > 0 and drops / total > self._alert_thresholds["packet_drop_ratio"]:
            logging.warning(
                f"ALERT: High packet drop ratio: {drops/total:.2%}"
            )
    
    def get_metrics_snapshot(self, region: Optional[str] = None) -> Dict:
        """Get current metrics snapshot."""
        snapshot = {
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "total_events": len(self.metrics_history),
        }
        
        if self.metrics:
            for name, metric in self.metrics.items():
                try:
                    if hasattr(metric, 'collect'):
                        samples = list(metric.collect())
                        snapshot[name] = len(samples)
                except Exception:
                    pass
        
        return snapshot


