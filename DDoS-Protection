    async def process_incoming_packet(self, packet: bytes,
                                     client_ip: str) -> PacketVerdict:
        """
        Main packet processing entry point.
        Routes packet through the entire defense matrix.
        """
        start_time = time.time()
        
        try:
            # Find nearest scrubbing center
            center = await self.anycast_controller.find_nearest_center(client_ip)
            
            # Extract flow key
            flow_key = FlowKey.from_packet(packet)
            
            # Get or create flow state
            if flow_key not in center._active_flows:
                flow = FlowState(
                    key=flow_key,
                    created_at=time.time(),
                    last_seen=time.time(),
                    scrubbing_center=center.region
                )
                center._active_flows[flow_key] = flow
            else:
                flow = center._active_flows[flow_key]
            
            # Update flow metrics
            flow.packets_in += 1
            flow.bytes_in += len(packet)
            flow.last_seen = time.time()
            
            # Process through all defense layers
            verdict = await center.process_packet(packet, flow)
            
            # Record telemetry
            latency_ms = (time.time() - start_time) * 1000
            await self.telemetry.record_packet(verdict, center.region, latency_ms)
            
            # Handle verdict
            if verdict == PacketVerdict.DROP:
                self.defense_status["total_packets_processed"] += 1
            elif verdict == PacketVerdict.CHALLENGE:
                await self._issue_challenge(flow, center)
            elif verdict == PacketVerdict.ALLOW:
                self.defense_status["total_packets_processed"] += 1
            
            return verdict
            
        except Exception as e:
            logging.error(f"Packet processing failed: {e}")
            return PacketVerdict.DROP
    
    async def _issue_challenge(self, flow: FlowState,
                              center: ScrubbingCenter):
        """Issue challenge to suspicious client."""
        challenge = self.challenge_engine.generate_challenge(
            client_ip=socket.inet_ntoa(struct.pack("!I", flow.key.src_ip)),
            difficulty="medium"
        )
        
        # In production, would send challenge to client
        logging.info(f"Challenge issued to {flow.key.src_ip}: {challenge['token'][:16]}...")
    
    async def _periodic_signature_update(self):
        """Periodically update attack signatures."""
        while True:
            await asyncio.sleep(DefenseConstants.SIGNATURE_UPDATE_INTERVAL)
            
            # In production, would fetch from threat intelligence feeds
            current_time = datetime.now(timezone.utc)
            for sig_id, sig in self.signatures.items():
