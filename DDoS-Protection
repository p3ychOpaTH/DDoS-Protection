class AdaptiveChallengeEngine:
    """
    Generates and validates cryptographic challenges to filter bots.
    Supports proof-of-work with adaptive difficulty based on threat level.
    
    Author: p3ychOpaTH
    """
    
    def __init__(self, secret: Optional[bytes] = None):
        self.secret = secret or secrets.token_bytes(64)
        self._difficulty_cache: Dict[str, Tuple[int, str]] = {}
        self._nonce_counter = 0
        self._hmac_key = secrets.token_bytes(32)
        self._fernet = None
        self._init_fernet()
    
    def _init_fernet(self):
        """Initialize Fernet encryption with derived key."""
        kdf = hashlib.pbkdf2_hmac('sha512', self.secret, b'hyperion_salt', 200000)
        key = hashlib.sha256(kdf).digest()
        self._fernet = Fernet(key)
    
    def generate_challenge(
        self, client_ip: str, difficulty: str = "medium",
        vector: Optional[AttackVector] = None
    ) -> Dict[str, Any]:
        """
        Generate a cryptographic challenge for a client.
        
        Args:
            client_ip: IP address of the client
            difficulty: Predefined difficulty level
            vector: Attack vector to adapt difficulty
        
        Returns:
            Challenge dictionary with token and parameters
        """
        config = DefenseConstants.CHALLENGE_COMPLEXITY[difficulty]
        target_difficulty = config["difficulty"]
        algorithm = config["algorithm"]
        
        # Adapt difficulty based on attack severity
        if vector in (AttackVector.HTTP_FLOOD, AttackVector.HTTPS_FLOOD):
            target_difficulty *= 2
        elif vector == AttackVector.DNS_AMPLIFICATION:
            target_difficulty *= 3
        
        nonce = secrets.token_hex(16)
        timestamp = int(time.time())
        
        payload = f"{client_ip}:{nonce}:{timestamp}"
        signature = hmac.new(
            self._hmac_key, payload.encode(), 'sha256'
        ).hexdigest()
        
        challenge = {
            "token": f"{nonce}:{timestamp}:{signature}",
            "difficulty": target_difficulty,
            "algorithm": algorithm,
            "timeout": DefenseConstants.CHALLENGE_TIMEOUT,
            "version": 2
        }
        
        self._difficulty_cache[client_ip] = (target_difficulty, nonce)
        return challenge
    
    def validate_challenge(
        self, client_ip: str, solution: str, token: str
    ) -> Tuple[bool, float]:
        """
        Validate a challenge solution.
        
        Returns:
            Tuple of (is_valid, time_taken_seconds)
        """
        try:
            parts = token.split(":")
            if len(parts) != 3:
                return False, 0.0
            
            nonce, timestamp_str, signature = parts
            timestamp = int(timestamp_str)
            
            # Verify token freshness
            if abs(time.time() - timestamp) > DefenseConstants.CHALLENGE_TIMEOUT:
                return False, 0.0
            
            # Verify signature
            payload = f"{client_ip}:{nonce}:{timestamp}"
            expected_sig = hmac.new(
                self._hmac_key, payload.encode(), 'sha256'
            ).hexdigest()
            
            if not hmac.compare_digest(signature, expected_sig):
                return False, 0.0
            
            # Check if this nonce was already used
            if nonce in self._used_nonces:
                return False, 0.0
            self._used_nonces.add(nonce)
            
            # Validate proof-of-work
            difficulty, _ = self._difficulty_cache.get(client_ip, (1000, nonce))
            solution_valid = self._verify_pow(solution, nonce, difficulty)
            
            return solution_valid, time.time() - timestamp
        
        except Exception:
            return False, 0.0
    
    def _verify_pow(self, solution: str, nonce: str, difficulty: int) -> bool:
        """Verify proof-of-work solution."""
        try:
            combined = f"{solution}:{nonce}"
            hash_result = hashlib.sha512(combined.encode()).hexdigest()
            hash_value = int(hash_result, 16)
            threshold = (2 ** 512) // difficulty
            return hash_value < threshold
        except Exception:
            return False
    
    def generate_syn_cookie(
        self, src_ip: str, src_port: int, dst_port: int, mss: int = 1460
    ) -> int:
        """
        Generate SYN cookie as per the TCP SYN cookie algorithm.
        Uses a secret key to prevent cookie forgery.
        """
        # Encode MSS in top 3 bits
        mss_index = [0, 536, 1460, 8960].index(mss) if mss in [0, 536, 1460, 8960] else 2
        timestamp = int(time.time()) // 64  # 6 bits for counter
        counter = timestamp & 0x3F
        
        # Create hash of (src_ip, src_port, dst_port, counter, secret)
        data = f"{src_ip}:{src_port}:{dst_port}:{counter}"
        mac = hmac.new(self._hmac_key, data.encode(), 'sha256').digest()
        
        cookie = (mss_index << 29) | (counter << 24) | (struct.unpack("!I", mac[:4])[0] & 0x00FFFFFF)
        return cookie
    
    def validate_syn_cookie(self, cookie: int, src_ip: str,
                            src_port: int, dst_port: int) -> bool:
        """Validate a received SYN cookie."""
        mss_index = (cookie >> 29) & 0x07
        counter = (cookie >> 24) & 0x3F
        mac_received = cookie & 0x00FFFFFF
        
        current_counter = (int(time.time()) // 64) & 0x3F
        
        # Accept cookies within 4 minutes window
        for delta in range(-2, 3):
            check_counter = (current_counter + delta) & 0x3F
            if check_counter == counter:
                data = f"{src_ip}:{src_port}:{dst_port}:{counter}"
                mac = hmac.new(self._hmac_key, data.encode(), 'sha256').digest()
                mac_computed = struct.unpack("!I", mac[:4])[0] & 0x00FFFFFF
                return mac_received == mac_computed
        
        return False
    
    _used_nonces: Set[str] = set()


