class TLSOffloadingEngine:
    """
    TLS/SSL Offloading Engine.
    Handles TLS termination, certificate management, and secure re-encryption.
    """
    
    def __init__(self):
        self.ssl_context = None
        self.cert_cache: Dict[str, Tuple[ssl.SSLContext, float]] = {}
        self.session_tickets: Dict[bytes, datetime] = {}
        self._setup_ssl_context()
    
    def _setup_ssl_context(self):
        """Setup SSL context with optimal security settings."""
        try:
            self.ssl_context = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
            self.ssl_context.options |= ssl.OP_NO_TLSv1 | ssl.OP_NO_TLSv1_1 | ssl.OP_NO_TLSv1_2
            self.ssl_context.options |= ssl.OP_NO_COMPRESSION
            self.ssl_context.options |= ssl.OP_CIPHER_SERVER_PREFERENCE
            self.ssl_context.options |= ssl.OP_SINGLE_DH_USE
            self.ssl_context.options |= ssl.OP_SINGLE_ECDH_USE
            
            # Set minimum TLS version to 1.3
            self.ssl_context.minimum_version = ssl.TLSVersion.TLSv1_3
            
            # Set cipher suite
            self.ssl_context.set_ciphers(':'.join(DefenseConstants.TLS_CIPHERS))
            
            # Load certificates (in production, from secure storage)
            self.ssl_context.load_cert_chain(
                DefenseConstants.TLS_CERT_PATH,
                DefenseConstants.TLS_KEY_PATH
            )
            
            # Setup session ticket rotation
            self._session_ticket_key = secrets.token_bytes(48)
            
        except Exception as e:
            logging.error(f"SSL context setup failed: {e}")
    
    def get_ssl_context(self, sni_hostname: Optional[str] = None) -> ssl.SSLContext:
        """Get SSL context, optionally for specific SNI hostname."""
        if sni_hostname and sni_hostname in self.cert_cache:
            ctx, expiry = self.cert_cache[sni_hostname]
            if time.time() < expiry:
                return ctx
        
        return self.ssl_context
    
    def generate_session_ticket(self) -> bytes:
        """Generate encrypted session ticket for TLS resumption."""
        ticket = secrets.token_bytes(32)
        encrypted = self._encrypt_ticket(ticket)
        self.session_tickets[ticket] = datetime.now(timezone.utc)
        return encrypted
    
    def validate_session_ticket(self, encrypted_ticket: bytes) -> bool:
        """Validate a TLS session ticket."""
        try:
            ticket = self._decrypt_ticket(encrypted_ticket)
            if ticket in self.session_tickets:
                created = self.session_tickets[ticket]
                if datetime.now(timezone.utc) - created < timedelta(hours=24):
                    return True
                del self.session_tickets[ticket]
        except Exception:
            pass
        return False
    
    def _encrypt_ticket(self, data: bytes) -> bytes:
        """Encrypt session ticket data."""
        cipher = Cipher(
            algorithms.AES(self._session_ticket_key[:32]),
            modes.GCM(self._session_ticket_key[32:44]),
            backend=default_backend()
        )
        encryptor = cipher.encryptor()
        return encryptor.update(data) + encryptor.finalize()
    
    def _decrypt_ticket(self, encrypted: bytes) -> bytes:
        """Decrypt session ticket data."""
        cipher = Cipher(
            algorithms.AES(self._session_ticket_key[:32]),
            modes.GCM(self._session_ticket_key[32:44]),
            backend=default_backend()
        )
        decryptor = cipher.decryptor()
        return decryptor.update(encrypted) + decryptor.finalize()
    
    def rotate_keys(self):
        """Rotate session ticket keys periodically."""
        self._session_ticket_key = secrets.token_bytes(48)
        # Clear old tickets
        cutoff = datetime.now(timezone.utc) - timedelta(hours=24)
        self.session_tickets = {
            k: v for k, v in self.session_tickets.items() if v > cutoff
        }


