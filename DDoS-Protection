class ForensicLogger:
    """
    Tamper-proof forensic logging system.
    Records all security events with cryptographic integrity verification.
    """
    
    def __init__(self, log_path: str = "/var/log/hyperion/forensic/"):
        self.log_path = Path(log_path)
        self.log_path.mkdir(parents=True, exist_ok=True)
        self.current_log_file = None
        self.log_chain_hash = secrets.token_hex(32)  # Genesis hash
        self.entries_written = 0
        
    async def initialize(self):
        """Initialize forensic logging."""
        self.current_log_file = self.log_path / f"forensic_{datetime.now().strftime('%Y%m%d_%H%M%S')}.log"
        logging.info(f"Forensic logging initialized: {self.current_log_file}")
        
        # Write genesis block
        await self._write_entry({
            "event": "GENESIS",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "chain_start_hash": self.log_chain_hash,
            "shield_version": DefenseConstants.VERSION
        })
    
    async def log_event(self, event_type: str, data: Dict[str, Any],
                       severity: str = "INFO"):
        """Log a forensic event with chain validation."""
        try:
            entry = {
                "event": event_type,
                "severity": severity,
                "timestamp": datetime.now(timezone.utc).isoformat(),
                "data": data,
                "previous_hash": self.log_chain_hash,
                "entry_number": self.entries_written
            }
            
            # Calculate entry hash
            entry_json = json.dumps(entry, sort_keys=True, default=str)
            entry_hash = hashlib.sha512(entry_json.encode()).hexdigest()
            entry["entry_hash"] = entry_hash
            
            # Update chain hash
            self.log_chain_hash = hashlib.sha256(
                (self.log_chain_hash + entry_hash).encode()
            ).hexdigest()
            entry["chain_hash"] = self.log_chain_hash
            
            # Write entry
            await self._write_entry(entry)
            self.entries_written += 1
            
            # Rotate log file if needed
            if self.entries_written % 1000000 == 0:
                await self._rotate_log()
                
        except Exception as e:
            logging.error(f"Forensic logging failed: {e}")
    
    async def _write_entry(self, entry: Dict[str, Any]):
        """Write forensic entry to log file."""
        if self.current_log_file:
            with open(self.current_log_file, 'a') as f:
                f.write(json.dumps(entry, default=str) + '\n')
    
    async def _rotate_log(self):
        """Rotate forensic log file."""
        self.current_log_file = self.log_path / f"forensic_{datetime.now().strftime('%Y%m%d_%H%M%S')}.log"
        logging.info(f"Forensic log rotated: {self.current_log_file}")
    
    async def verify_integrity(self) -> bool:
        """Verify forensic log chain integrity."""
        if not self.current_log_file or not self.current_log_file.exists():
            return False
        
        try:
            with open(self.current_log_file, 'r') as f:
                lines = f.readlines()
            
            previous_hash = None
            for line in lines:
                entry = json.loads(line.strip())
                
                # Verify previous hash chain
                if previous_hash and entry.get("previous_hash") != previous_hash:
                    logging.critical(f"Forensic chain broken at entry {entry.get('entry_number')}")
                    return False
                
                # Verify entry hash
                verify_entry = {k: v for k, v in entry.items()
                               if k not in ("entry_hash", "chain_hash")}
                verify_json = json.dumps(verify_entry, sort_keys=True, default=str)
                computed_hash = hashlib.sha512(verify_json.encode()).hexdigest()
                
                if computed_hash != entry.get("entry_hash"):
                    logging.critical(f"Entry tampered at {entry.get('entry_number')}")
                    return False
                
                previous_hash = entry.get("entry_hash")
            
            return True
            
        except Exception as e:
            logging.error(f"Integrity verification failed: {e}")
            return False


