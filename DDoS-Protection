class CDNIntegration:
    """
    Content Delivery Network Integration.
    Provides caching, edge distribution, and origin shielding.
    """
    
    def __init__(self):
        self.cache: Dict[str, Tuple[bytes, float, Dict[str, str]]] = {}
        self.cache_hits = 0
        self.cache_misses = 0
        self.origin_connections: Dict[str, asyncio.Queue] = {}
        self._cache_lock = asyncio.Lock()
    
    async def get_cached_content(self, url: str) -> Optional[Tuple[bytes, Dict[str, str]]]:
        """Retrieve content from edge cache."""
        async with self._cache_lock:
            if url in self.cache:
                content, expiry, headers = self.cache[url]
                if time.time() < expiry:
                    self.cache_hits += 1
                    return content, headers
                else:
                    del self.cache[url]
        
        self.cache_misses += 1
        return None
    
    async def cache_content(self, url: str, content: bytes,
                           headers: Dict[str, str], ttl: int = 3600):
        """Cache content at the edge."""
        async with self._cache_lock:
            expiry = time.time() + ttl
            
            # Implement LRU eviction if cache is too large
            if len(self.cache) >= DefenseConstants.CACHE_MAX_ENTRIES:
                # Remove oldest 10% of entries
                sorted_items = sorted(
                    self.cache.items(), key=lambda x: x[1][1]
                )
                for old_url, _ in sorted_items[:len(self.cache) // 10]:
                    del self.cache[old_url]
            
            self.cache[url] = (content, expiry, headers)
    
    def get_cache_stats(self) -> Dict[str, Any]:
        """Get cache performance statistics."""
        total = self.cache_hits + self.cache_misses
        hit_ratio = self.cache_hits / total if total > 0 else 0
        return {
            "hits": self.cache_hits,
            "misses": self.cache_misses,
            "hit_ratio": hit_ratio,
            "cached_items": len(self.cache),
            "cache_size_bytes": sum(len(v[0]) for v in self.cache.values())
        }
    
    async def purge_cache(self, pattern: Optional[str] = None):
        """Purge cache entries matching pattern."""
        async with self._cache_lock:
            if pattern:
                keys_to_remove = [k for k in self.cache if pattern in k]
                for k in keys_to_remove:
                    del self.cache[k]
            else:
                self.cache.clear()


