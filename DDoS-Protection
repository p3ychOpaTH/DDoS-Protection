            "GET /api/v1/metrics": self.handle_metrics,
            "GET /api/v1/configuration": self.handle_get_config,
            "POST /api/v1/configuration/reload": self.handle_reload_config,
            "GET /api/v1/health": self.handle_health,
            "POST /api/v1/challenge": self.handle_manual_challenge,
        }
        return routes
    
    async def _handle_request(self, reader: asyncio.StreamReader,
                             writer: asyncio.StreamWriter):
        """Handle incoming API request."""
        try:
            # Read request line
            request_line = await asyncio.wait_for(
                reader.readline(), timeout=30
            )
            if not request_line:
                writer.close()
                return
            
            request_str = request_line.decode().strip()
            method, path, _ = request_str.split(' ')
            
            # Read headers
            headers = {}
            while True:
                header_line = await reader.readline()
                if header_line == b'\r\n' or not header_line:
                    break
                key, value = header_line.decode().strip().split(': ', 1)
                headers[key.lower()] = value
            
            # Read body if present
            body = b''
            if 'content-length' in headers:
                content_length = int(headers['content-length'])
                body = await reader.readexactly(content_length)
            
            # Authenticate
            api_key = headers.get('x-api-key', '')
            if not self._authenticate(api_key):
                await self._send_response(writer, 401, {"error": "Unauthorized"})
                return
            
            # Route request
            response = await self._route_request(method, path, body, headers)
            
            # Send response
            await self._send_response(writer, response.get('status', 200),
                                     response.get('body', {}))
            
        except Exception as e:
            try:
                await self._send_response(writer, 500, {"error": str(e)})
            except Exception:
                pass
        finally:
            writer.close()
    
    def _authenticate(self, api_key: str) -> bool:
        """Authenticate API request."""
        if not api_key:
            return False
        return api_key in self.api_keys
    
    async def _route_request(self, method: str, path: str,
                            body: bytes, headers: Dict) -> Dict:
        """Route API request to handler."""
        route_key = f"{method} {path}"
        
        handlers = self._create_app()
        if route_key in handlers:
            return await handlers[route_key](body, headers)
        
        # Check for parameterized routes
        for pattern, handler in handlers.items():
            if '{' in pattern:
                # Simple parameter matching
                pattern_parts = pattern.split('/')
                path_parts = path.split('/')
                if len(pattern_parts) == len(path_parts):
                    params = {}
                    match = True
                    for pp, rp in zip(pattern_parts, path_parts):
                        if pp.startswith('{') and pp.endswith('}'):
                            params[pp[1:-1]] = rp
                        elif pp != rp:
                            match = False
                            break
                    if match:
                        return await handler(body, headers, **params)
        
        return {"status": 404, "body": {"error": "Not found"}}
    
    async def _send_response(self, writer: asyncio.StreamWriter,
                            status: int, body: Dict):
        """Send HTTP response."""
        response_body = json.dumps(body).encode()
        response = (
            f"HTTP/1.1 {status} {self._status_text(status)}\r\n"
            f"Content-Type: application/json\r\n"
            f"Content-Length: {len(response_body)}\r\n"
            f"Server: Hyperion-Shield/{DefenseConstants.VERSION}\r\n"
            f"Connection: close\r\n"
            f"\r\n"
        ).encode() + response_body
        
        writer.write(response)
        await writer.drain()
    
    def _status_text(self, status: int) -> str:
        """Get HTTP status text."""
        status_map = {
            200: "OK", 201: "Created", 204: "No Content",
            400: "Bad Request", 401: "Unauthorized", 403: "Forbidden",
            404: "Not Found", 429: "Too Many Requests", 500: "Internal Server Error"
        }
        return status_map.get(status, "Unknown")
    
    # API Handlers
    async def handle_status(self, body: bytes, headers: Dict) -> Dict:
        """GET /api/v1/status - Get shield status."""
        status = self.shield.get_status()
        return {"status": 200, "body": status}
    
    async def handle_get_attacks(self, body: bytes, headers: Dict) -> Dict:
        """GET /api/v1/attacks - Get active attacks."""
        attacks = []
        for cont_centers in self.shield.anycast_controller.centers.values():
            for center in cont_centers.values():
                for mit_key, mit_time in center._attack_mitigations.items():
                    attacks.append({
                        "mitigation_key": mit_key,
                        "started": mit_time.isoformat(),
                        "region": center.region
                    })
        return {"status": 200, "body": {"active_attacks": attacks}}
    
    async def handle_mitigate(self, body: bytes, headers: Dict) -> Dict:
        """POST /api/v1/mitigate - Manual mitigation trigger."""
        try:
            data = json.loads(body)
            target = data.get('target')
            vector_name = data.get('vector', 'ZERO_DAY_VECTOR')
            
            if target:
                vector = getattr(AttackVector, vector_name, AttackVector.ZERO_DAY_VECTOR)
                for cont_centers in self.shield.anycast_controller.centers.values():
                    for center in cont_centers.values():
                        center._trigger_mitigation(vector, target)
                
                return {"status": 200, "body": {
                    "message": f"Mitigation triggered for {target}",
                    "vector": vector_name
                }}
        except Exception as e:
            return {"status": 400, "body": {"error": str(e)}}
        
        return {"status": 400, "body": {"error": "Invalid request"}}
    
    async def handle_blacklist(self, body: bytes, headers: Dict) -> Dict:
        """POST /api/v1/blacklist - Add IP to blacklist."""
        try:
            data = json.loads(body)
            ip = data.get('ip')
            duration = data.get('duration_hours', 24)
            
            if ip:
                # Add to all center blacklists
                for cont_centers in self.shield.anycast_controller.centers.values():
                    for center in cont_centers.values():
                        if not hasattr(center, '_blackhole_list'):
                            center._blackhole_list = set()
                        try:
                            ip_int = struct.unpack("!I",
                                socket.inet_aton(ip))[0]
                            center._blackhole_list.add(ip_int)
                        except Exception:
                            pass
                
                return {"status": 200, "body": {
                    "message": f"IP {ip} blacklisted for {duration} hours"
                }}
        except Exception as e:
            return {"status": 400, "body": {"error": str(e)}}
        
        return {"status": 400, "body": {"error": "Invalid request"}}
    
    async def handle_remove_blacklist(self, body: bytes, headers: Dict,
                                     ip: str = "") -> Dict:
        """DELETE /api/v1/blacklist/{ip} - Remove IP from blacklist."""
        try:
            ip_int = struct.unpack("!I", socket.inet_aton(ip))[0]
            for cont_centers in self.shield.anycast_controller.centers.values():
                for center in cont_centers.values():
                    if hasattr(center, '_blackhole_list'):
                        center._blackhole_list.discard(ip_int)
            return {"status": 200, "body": {"message": f"IP {ip} removed from blacklist"}}
        except Exception as e:
            return {"status": 400, "body": {"error": str(e)}}
    
    async def handle_metrics(self, body: bytes, headers: Dict) -> Dict:
        """GET /api/v1/metrics - Get Prometheus metrics."""
        snapshot = self.shield.telemetry.get_metrics_snapshot()
        return {"status": 200, "body": snapshot}
    
    async def handle_get_config(self, body: bytes, headers: Dict) -> Dict:
        """GET /api/v1/configuration - Get current configuration."""
        return {"status": 200, "body": self.shield.config.config if hasattr(self.shield, 'config') else {}}
    
    async def handle_reload_config(self, body: bytes, headers: Dict) -> Dict:
        """POST /api/v1/configuration/reload - Reload configuration."""
        if hasattr(self.shield, 'config'):
            await self.shield.config.load_config()
        return {"status": 200, "body": {"message": "Configuration reloaded"}}
    
    async def handle_health(self, body: bytes, headers: Dict) -> Dict:
        """GET /api/v1/health - Health check endpoint."""
        return {"status": 200, "body": {
            "status": self.shield.defense_status["status"],
            "version": DefenseConstants.VERSION,
            "timestamp": datetime.now(timezone.utc).isoformat()
        }}
    
    async def handle_manual_challenge(self, body: bytes, headers: Dict) -> Dict:
        """POST /api/v1/challenge - Issue manual challenge."""
        try:
            data = json.loads(body)
            client_ip = data.get('ip')
            difficulty = data.get('difficulty', 'high')
            
            if client_ip:
                challenge = self.shield.challenge_engine.generate_challenge(
                    client_ip, difficulty
                )
                return {"status": 200, "body": challenge}
        except Exception as e:
            return {"status": 400, "body": {"error": str(e)}}
        
        return {"status": 400, "body": {"error": "Invalid request"}}


