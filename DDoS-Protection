    @staticmethod
    async def _cmd_stop(args):
        """Handle stop command."""
        pid_file = Path("/var/run/hyperion/shield.pid")
        
        if not pid_file.exists():
            print("Shield is not running (PID file not found)")
            return
        
        try:
            with open(pid_file, 'r') as f:
                pid = int(f.read().strip())
            
            if args.force:
                os.kill(pid, signal.SIGKILL)
                print(f"Force killed PID {pid}")
            else:
                os.kill(pid, signal.SIGTERM)
                print(f"Sent shutdown signal to PID {pid}")
                
                # Wait for graceful shutdown
                for _ in range(30):
                    try:
                        os.kill(pid, 0)
                        await asyncio.sleep(1)
                    except OSError:
                        print("Shield stopped successfully")
                        return
                
                print("Shield did not stop gracefully, use --force to kill")
        except ProcessLookupError:
            print("Shield process not found")
        except Exception as e:
            print(f"Error stopping shield: {e}")
    
